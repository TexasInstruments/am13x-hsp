%% hwi_am13x.tlc
%%
%% Abstract:
%%   TLC block file for the hwi_am13x S-function.
%%   Generates a hardware ISR wrapper function for the TI AM13x
%%   (AM263x / AM243x) Vector Interrupt Manager (VIM).
%%
%%   The generated ISR wrapper:
%%     1. Has the exact function name configured in the block mask.
%%     2. Inlines the connected function-call subsystem body.
%%
%%   For each instance of this block the following is emitted into
%%   the model source file:
%%
%%       void Timer0_IRQHandler(void)
%%       {
%%           <inlined subsystem body>
%%       }
%%

%% Copyright (C) 2026 Texas Instruments Incorporated
%%     %
