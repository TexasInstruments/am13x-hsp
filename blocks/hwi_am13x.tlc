%implements hwi_am13x "C"

%% =========================================================================
%% BlockTypeSetup
%% Called once per block type per model build.
%% Add any model-wide includes that the ISR wrapper depends on.
%% =========================================================================
%function BlockTypeSetup(block, system) void

    %% Include the AM13x interrupt controller driver header.
    %% Adjust the path to match your SDK installation if needed.
    %<LibAddToCommonIncludes("<driverlib.h>")>

%endfunction


%% =========================================================================
%% BlockInstanceSetup
%% Warn if the function-call output is not connected to any subsystem.
%% =========================================================================
%function BlockInstanceSetup(block, system) void

    %if LibIsEqual(SFcnSystemOutputCall[0].BlockToCall, "unconnected")
        %assign wrnTxt = "No code will be generated for ISR '%<Name>' " ...
                         "since it is not connected to a subsystem."
        %<LibReportWarning(wrnTxt)>
    %endif

%endfunction


%% =========================================================================
%% Outputs
%% Emits the ISR function at file scope with the subsystem body inlined.
%% =========================================================================
%function Outputs(block, system) Output

    %assign callIdx     = 0
    %assign handlerName = SFcnParamSettings.HANDLER_NAME
    %assign prologCode  = SFcnParamSettings.PROLOG_CODE
    %assign epilogCode  = SFcnParamSettings.EPILOG_CODE

    %% Capture the inlined contents of the connected function-call subsystem
    %openfile tmpBuf
    %<LibBlockExecuteFcnCall(block, callIdx)>\
    %closefile tmpBuf

    %% Build the ISR function and place it at file scope
    %openfile funcBuf
    /* AM13x Hardware Interrupt: '%<Name>' */
    void %<handlerName>(void)
    {
        %if !LibIsEqual(prologCode, "")
        /* Prolog - e.g. clear interrupt flag */
        %<prologCode>;
        %endif

        %<tmpBuf>
        %if !LibIsEqual(epilogCode, "")
        /* Epilog - e.g. re-enable interrupt */
        %<epilogCode>;
        %endif
    }

    %closefile funcBuf
    %<LibSetSourceFileSection(LibGetModelDotCFile(), "Functions", funcBuf)>

%endfunction

%% EOF: hwi_am13x.tlc